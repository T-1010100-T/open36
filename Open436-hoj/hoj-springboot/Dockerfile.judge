# ── HOJ JudgeServer ── 多阶段构建 (Java 8)
FROM maven:3.8-openjdk-8 AS builder
WORKDIR /build
COPY pom.xml .
COPY api/pom.xml api/pom.xml
COPY DataBackup/pom.xml DataBackup/pom.xml
COPY JudgeServer/pom.xml JudgeServer/pom.xml
RUN mvn dependency:go-offline -B -pl JudgeServer -am
COPY . .
RUN mvn package -DskipTests -B -pl JudgeServer -am

FROM openjdk:8-jre-slim
WORKDIR /app
COPY --from=builder /build/JudgeServer/target/*.jar app.jar
EXPOSE 8088
ENTRYPOINT ["java", "-jar", "app.jar"]
